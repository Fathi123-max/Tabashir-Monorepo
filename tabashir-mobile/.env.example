# API Configuration Template
# Copy this file to .env and fill in your values

# Base URL for the Python Backend API (local development: http://10.0.2.2:5050 for emulator or http://localhost:5050)
API_BASE_URL=http://10.0.2.2:5050

# Tabashir API Token for authenticating service-to-service calls
TABASHIR_API_TOKEN=your_api_token_here

# Backend API Token for backend.tabashir.ae
BACKEND_API_TOKEN=your_backend_api_token_here
